{
    "name": "squadforge",
    "version": "0.1.0",
    "description": "Opinionated JavaScript framework for main-agent and subagent squads",
    "type": "module",
    "main": "./src/index.js",
    "exports": {
        ".": "./src/index.js"
    },
    "scripts": {
        "test": "node --test ./tests/**/*.test.js",
        "example": "node ./examples/basic/run.js",
        "example:real": "node ./examples/basic/run.js"
    },
    "files": [
        "src",
        "README.md",
        "examples"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "ai",
        "agent",
        "framework",
        "multi-agent",
        "subagent",
        "llm"
    ],
    "dependencies": {
        "node-cron": "4.2.1",
        "openai": "6.18.0",
        "winston": "3.19.0"
    },
    "license": "MIT"
}